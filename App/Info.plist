	<string>Open Voice Typer records audio during a dictation session to transcribe your speech.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Used for on-device speech recognition when Apple ASR is selected.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
